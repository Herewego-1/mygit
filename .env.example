# ========================================
# WEGO 자동화 시스템 - API 키 설정 파일
# ========================================
# 사용법:
#   1. 이 파일을 복사해서 .env 로 저장
#   2. 각 값을 실제 API 키로 교체
#   3. .env 파일은 절대 Git에 올리지 말 것!
# ========================================

# ----- Perplexity AI (리서치 담당) -----
# 발급처: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-여기에_실제_API키_입력

# ----- Ollama 로컬 LLM (한국어 리라이팅) -----
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ----- Obsidian Vault (로컬 저장소) -----
OBSIDIAN_VAULT_PATH=C:\Users\UserPC\Obsidian

# ----- Telegram 봇 (알림) -----
# 발급처: @BotFather 에게 /newbot 메시지 전송
TELEGRAM_BOT_TOKEN=여기에_봇_토큰_입력
TELEGRAM_CHAT_ID=여기에_채팅ID_입력

# ----- n8n 설정 -----
N8N_HOST=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=여기에_비밀번호_입력

# ----- Gemini (Fallback 1순위) -----
# 발급처: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=여기에_Gemini_API키_입력

# ----- 선택사항: Claude API (Fallback 최종) -----
# CLAUDE_API_KEY=sk-ant-여기에_Claude_API키_입력
